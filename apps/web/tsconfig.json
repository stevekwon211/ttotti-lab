{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@ttotti/effects": ["../../packages/effects/src/index.ts"],
      "@ttotti/effects/*": ["../../packages/effects/src/*"],
      "@ttotti/hand-particles": ["../../experiments/hand-particles/src/index.ts"],
      "@ttotti/hand-particles/*": ["../../experiments/hand-particles/src/*"],
      "@ttotti/ui/*": ["../../packages/ui/src/*"],
      "@ttotti/vision": ["../../packages/vision/src/index.ts"],
      "@ttotti/vision/*": ["../../packages/vision/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
